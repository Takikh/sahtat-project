# Supabase Configuration (Frontend)
# Copy this file to .env and fill in your values.
# In Vercel: add these as Environment Variables in the dashboard.
#
# IMPORTANT:
# - This file is for browser-safe VITE_* variables only.
# - Never put SUPABASE_SERVICE_ROLE_KEY or sb_secret_* here.

# Your Supabase project ID (found in Settings > General)
VITE_SUPABASE_PROJECT_ID="your-project-id"

# Your Supabase project URL (found in Settings > API)
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Preferred: Supabase Publishable Key (starts with sb_publishable_)
# Fallback compatible: legacy anon JWT/public key
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxxxxxxxxxxxxxx"
